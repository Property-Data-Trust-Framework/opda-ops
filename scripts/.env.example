# .env.example — template for OPDA API repo GitHub environment setup.
#
# Copy this file to .env.<environment> (e.g. .env.dev), fill in the values,
# then source it before running setup-github-env.sh:
#
#   source scripts/.env.dev
#   ./scripts/setup-github-env.sh --repo Property-Data-Trust-Framework/opda-lr-facade --env dev --no-submodules
#
# NEVER commit a populated .env.* file to git.
# Add .env.* to .gitignore.
#
# Multi-line PEM values: use command substitution, e.g.:
#   export GH_SECRET_TRANSPORT_CERTIFICATE="$(cat path/to/transport.crt)"
#
# ── Auto-resolved from AWS (leave blank to resolve automatically) ─────────────
#
# These values are looked up from AWS if left empty. Set them explicitly to
# override auto-resolution (e.g. to target a specific hosted zone when the
# account has more than one).

# ARN of the GitHub Actions IAM role — resolved from IAM role <repo>-github-actions.
export GH_SECRET_AWS_ROLE_ARN=""

# Route53 public hosted zone ID and domain — resolved from Route53 automatically
# when the account has exactly one public hosted zone. Set EXTERNAL_DOMAIN_NAME
# to disambiguate when multiple zones exist.
export GH_SECRET_EXTERNAL_HOSTED_ZONE_ID=""
export GH_VAR_EXTERNAL_DOMAIN_NAME=""

# Shared services ECR URI and image tags — resolved from the opda-shared-services
# ECR repository. Requires the shared-services bootstrap and publish pipeline to
# have run at least once.
export GH_VAR_SHARED_SERVICES_ECR_BASE=""
export GH_VAR_AUTHORIZER_IMAGE_TAG=""
export GH_VAR_MTLS_PROXY_IMAGE_TAG=""

# ── Must be set manually ──────────────────────────────────────────────────────

# OAuth2 client ID registered with the authorisation server.
export GH_SECRET_OAUTH_CLIENT_ID=""

# OAuth2 issuer URL — no trailing slash. e.g. https://auth.example.com
export GH_VAR_OAUTH_ISSUER=""

# mTLS proxy transport TLS credentials (server-side — presented by the NLB to clients).
export GH_SECRET_TRANSPORT_CERTIFICATE=""   # PEM
export GH_SECRET_TRANSPORT_KEY=""           # PEM (sensitive)

# CA bundle trusted for verifying incoming mTLS client certificates.
export GH_SECRET_CA_TRUSTED_LIST=""         # PEM bundle

# RS256 private key for private_key_jwt assertions to the authorisation server.
# Use a placeholder value when BYPASS_AUTH=true during initial development.
export GH_SECRET_SIGNING_KEY=""             # PEM (sensitive)

# KID issued by Raidiam for the provenance signing cert (server/provenance/).
# This is a distinct cert from SIGNING_KEY — generated separately in the Raidiam portal.
export GH_VAR_PROVENANCE_SIGNING_KID=""

# PEM RS256 private key for signing response payloads (provenance).
export GH_SECRET_DATAPROV_KEY=""            # PEM (sensitive)

# ── API-specific credentials (example — not part of the generic setup) ────────
#
# These are examples of the kind of API-specific secrets your repo may need.
# Add them to a repo-specific .env file and wire them up in your own Terraform.
# Do NOT add them to the arrays in setup-github-env.sh — they belong per-repo.

# Example: HMLR Business Gateway credentials (opda-lr-facade only).
# export GH_SECRET_HMLR_USERNAME=""
# export GH_SECRET_HMLR_PASSWORD=""
# export GH_VAR_HMLR_ENDPOINT=""           # SOAP endpoint URL
# export GH_SECRET_HMLR_CLIENT_CERT=""     # PEM — client cert for mTLS to HMLR
# export GH_SECRET_HMLR_CLIENT_KEY=""      # PEM (sensitive)
