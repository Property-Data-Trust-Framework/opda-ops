# Optional local-dev overrides for sync-specs.sh. Copy to server-urls.env
# (gitignored) and fill in the live NLB DNS for any API you want to mirror
# the CI substitution behaviour against locally. Leave any unset to keep the
# spec's default placeholder.
#
# Look up via:
#   aws elbv2 describe-load-balancers --names opda-lr-facade --query "LoadBalancers[0].DNSName" --output text --region eu-west-2

OPDA_LR_FACADE_HOST=
OPDA_UPRN_VALIDATOR_HOST=
OPDA_MRA_API_HOST=
OPDA_OS_API_HOST=
