# Populated env files — contain secrets
scripts/.env.*
!scripts/.env.example
scripts/bruno.env

# Key material — folder structure is tracked, contents are not
# CA bundles are public and safe to commit; private key material is not
keys/**
!keys/**/.gitkeep
!keys/**/ca/*.pem

# Terraform working dirs
**/.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# Populated tfvars — contain secrets
*.tfvars
!*.tfvars.example
# Non-secret IAM tfvars are committed (name + github_repo, no credentials)
!terraform/iam/terraform.tfvars
.DS_Store

# .NET build output
[Bb]in/
[Oo]bj/
[Tt]est[Rr]esult*/

# IDE
.idea/
.vs/
.vscode/
*.user
*.suo
*.DotSettings.user
_ReSharper*/
*.[Rr]e[Ss]harper
*.sln.iml
